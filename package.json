{
  "name": "susarna-core",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "test": "tsx --test test/*.test.ts",
    "server": "tsx watch src/server/index.ts",
    "start": "tsx src/server/index.ts",
    "dev": "concurrently -n server,web -c cyan,magenta \"npm run server\" \"npm --prefix web run dev\""
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "fastify": "^4.28.1",
    "tsx": "^4.15.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  }
}
